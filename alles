class GOKU(): 
    def __init__(self, controller): 
        self.image_right = pygame.image.load("GOKU .png")
        self.image_left = pygame.image.load("GOKU_reverse.png")
        self.surf = self.image_right
        self.richting = 1
        self.rechts = controller[3]
        self.links = controller[2]
        self.onder = controller[0]
        self.boven = controller[1]
        self.LG_ATT = controller[5]
        self.BOOST = controller[4]
        self.sprong = 0
        self.max_sprong = 2
        self.op_grond = False 
        self.rect = self.surf.get_rect() 
        self.rect.x = beginpos[0]
        self.rect.y = beginpos[1]
        self.gr = 0 
        self.dashing = False
        self.dashing_tijd = 0
        self.dashing_maxtijd = frame_count * 0.15
        self.dashing_cooldown = frame_count * 2
        self.dashing_Ctijd = 0 
        self.levens = 3
    def update(self,pressed_keys): 
        self.rect.y +=self.gr 
        if self.richting == 1:
            self.surf = self.image_right
        else:
            self.surf = self.image_left
        if self.rect.y <= 0 or self.rect.y >= scherm_display[1]  or self.rect.x <= 0 or self.rect.x >= scherm_display[0]:
            if self.levens >= 0 :
                self.rect.x = beginpos[0]
                self.rect.y = beginpos[1]
                self.levens -= 1
            else:
                draw_text("YOU WIN", text_font, groen, 670, 200)
                draw_text("YOU LOSE", text_font, rood, 80, 200)
                pygame.draw.line(scherm,zwart, (620,0),(620,720),20)
                
        if pressed_keys[self.BOOST] and not self.dashing and self.dashing_Ctijd >= self.dashing_cooldown:
            self.dashing = True
            self.dashing_tijd = 0
        
        if self.dashing:
            if self.dashing_tijd < self.dashing_maxtijd:
                self.rect.x += 25 * self.richting
                self.dashing_tijd += 1
            else:
                self.dashing = False
                self.dashing_Ctijd = 0
        if not self.dashing:
            self.dashing_Ctijd += 1
        if pressed_keys[self.LG_ATT]:
            if len(attaque) < 1:
                if self.richting == 1:
                    projectiel = long_range_att(self.rect.midright, self.richting)
                    attaque.append(projectiel)
                else:
                    projectiel = long_range_att(self.rect.midleft, self.richting)
                    attaque.append(projectiel)
        if pressed_keys[self.rechts]: 
            self.rect.x += snelheid 
            self.richting = 1
        if pressed_keys[self.links]: 
            self.rect.x -= snelheid
            self.richting = -1
        if pressed_keys[self.onder]: 
            if 480 <=self.rect.y <= 500 and 250 <= self.rect.x <= 950: 
                self.rect.y = 485
            else: 
                self.rect.y += beneden
        if pressed_keys[self.boven] and self.sprong <= self.max_sprong: 
            if self.sprong == 0:
                self.gr = -65
            else:
                self.gr = -40
            self.sprong += 1 
        elif 295<= self.rect.y <= 300 and 750 <= self.rect.x <= 1070: 
            self.rect.y = 300 
            self.gr = 0 
            self.sprong = 0
        elif 295<=self.rect.y <= 300 and 140 <= self.rect.x <= 460: 
            self.rect.y = 300 
            self.gr = 0 
            self.sprong = 0
        elif 480 <=self.rect.y <= 500 and 250 <= self.rect.x <= 950: 
            self.rect.y = 485 
            self.gr = 0 
            self.sprong = 0
        else: 
            self.gr += 5        
            self.gr = min(self.gr, 25)

 
class long_range_att():
    def __init__(self, center_personnage, direction):
        self.surf = pygame.Surface((20,20))
        self.surf.fill((blauw))
        self.rect = self.surf.get_rect(center = center_personnage )
        self.direction = direction
    def update(self):
        self.rect.x += (15 * self.direction)
        if self.rect.colliderect(speler_1.rect) or self.rect.colliderect(speler_2.rect):
            return True
        if self.rect.right >= 1280 or self.rect.left <= 0:
            return True  # markeer voor verwijdering
        return False



