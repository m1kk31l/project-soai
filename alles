class Cooldown:
    def __init__(self, max_tijd):
        self.max_tijd = max_tijd
        self.timer = max_tijd
 
    def update(self):
        if self.timer < self.max_tijd:
            self.timer += 1
 
    def gebruik(self):
        if self.klaar():
            self.timer = 0
            return True
        return False
 
    def klaar(self):
        return self.timer >= self.max_tijd
 
class GamecubeController:
    def __init__(self, joystick_id=0):
        pygame.joystick.init()
        self.joystick = pygame.joystick.Joystick(joystick_id)
        self.joystick.init()

        # axes
        self.axis_x = 0
        self.axis_y = 1

        # boutons (à adapter selon ton setup)
        self.BUTTON_A = 0
        self.BUTTON_B = 1
        self.BUTTON_X = 2
        self.BUTTON_Y = 3
        self.BUTTON_L = 4
        self.BUTTON_R = 5

    def get_inputs(self):
        inputs = {
            "left": False,
            "right": False,
            "up": False,
            "down": False,
            "jump": False,
            "attack": False,
            "special": False,
            "dash": False
        }

        x = self.joystick.get_axis(self.axis_x)
        y = self.joystick.get_axis(self.axis_y)

        # stick
        if x < -0.5:
            inputs["left"] = True
        if x > 0.5:
            inputs["right"] = True
        if y < -0.5:
            inputs["up"] = True
        if y > 0.5:
            inputs["down"] = True

        # boutons
        inputs["jump"] = self.joystick.get_button(self.BUTTON_A)
        inputs["attack"] = self.joystick.get_button(self.BUTTON_B)
        inputs["special"] = self.joystick.get_button(self.BUTTON_X)
        inputs["dash"] = self.joystick.get_button(self.BUTTON_R)

        return inputs


class GOKU():
    def __init__(self, controller, beginpos):
        self.image_right = pygame.image.load("GOKU .png")
        self.image_left = pygame.image.load("GOKU_reverse.png")
        self.surf = self.image_right
        self.richting = 1
        self.rechts = controller[3]
        self.links = controller[2]
        self.onder = controller[0]
        self.boven = controller[1]
        self.boven_ingedrukt = False
        self.LG_ATT = controller[5]
        self.Punch = controller[6]
        self.BOOST = controller[4]
        self.charged = controller[7]
        self.SHIELD = controller[8]
        self.sprong = 0
        self.max_sprong = 2
        self.rect = self.surf.get_rect()
        self.rect.x = beginpos[0]
        self.rect.y = beginpos[1]
        self.gr = 0
        self.op_grond = False
        self.dashing = False
        self.dashing_tijd = 0
        self.dashing_maxtijd = frame_count * 0.15
        self.dash_cooldown = Cooldown(frame_count * 2)
        self.levens = 3
        self.schade = 0.01
        self.freeze_timer = 0
        self.punch_cooldown_timer = 0
        self.cooldown_LG = Cooldown(frame_count*1)
        self.charge_attack = ChargeAttack(self)
        self.was_charging = False
        self.kb_x = 0
        self.kb_y = 0
        self.wrijving = 0.95
        self.cooldown = 2*frame_count
        self.shield = Shield(self)
 
    def update(self, pressed_keys):
        self.op_grond = False
        
        self.rect.x += self.kb_x
        self.rect.y += self.kb_y

        self.kb_x *= self.wrijving
        self.kb_y *= self.wrijving

        self.gr += 5
        self.gr = min(self.gr, 25)
        self.rect.y += self.gr
        
        

        for (x_min, x_max, y_land, y_check_min, y_check_max) in platforms:
            if y_check_min <= self.rect.bottom <= y_check_max and self.rect.right >= x_min and self.rect.left <= x_max and self.gr >= 0:
                self.rect.bottom = y_land
                self.gr = 0
                self.sprong = 0
                self.boven_ingedrukt = False
                self.op_grond = True
                break
        if self.richting == 1:
            self.surf = self.image_right
        else:
            self.surf = self.image_left
 
        if self.rect.y >= scherm_display[1] or self.rect.x <= 0 or self.rect.x >= scherm_display[0]:
            if self.levens > 0:
                self.rect.x = respawn_pos[0]
                self.rect.y = respawn_pos[1]
                self.gr = 0
                self.levens -= 1
                self.schade += 1
            else:
                self.levens = 0
 
        self.dash_cooldown.update()
        if pressed_keys[self.BOOST] and not self.dashing and self.dash_cooldown.gebruik():
            self.dashing = True
            self.dashing_tijd = 0
        if self.dashing:
            if self.dashing_tijd < self.dashing_maxtijd:
                self.rect.x += 25 * self.richting
                self.dashing_tijd += 1
            else:
                self.dashing = False
 
        self.cooldown_LG.update()
        if pressed_keys[self.LG_ATT] and self.cooldown_LG.gebruik():
            attaque.append(long_range_att(self, self.richting))
 
        if self.punch_cooldown_timer > 0:
            self.punch_cooldown_timer -= 1
        
        if pressed_keys[self.Punch]:
           if len(punches) < 1 and self.punch_cooldown_timer == 0:
               attaque.append(Punch(self))
               self.freeze_timer = 20
               self.punch_cooldown_timer = 30    
        
        
        if pressed_keys[self.charged]:
            self.charge_attack.start()
            self.was_charging = True
        else:
            if self.was_charging:
                projectile = self.charge_attack.release()
                if projectile:
                    attaque.append(projectile)
            self.was_charging = False

        self.charge_attack.update()
        
        
        self.shield.update(pressed_keys[self.SHIELD])
 
        if self.freeze_timer > 0:
            self.freeze_timer -= 1
 
        if self.freeze_timer == 0:
            if pressed_keys[self.rechts]:
                self.rect.x += snelheid
                self.richting = 1
            if pressed_keys[self.links]:
                self.rect.x -= snelheid
                self.richting = -1
 
            if pressed_keys[self.boven]:
                if not self.boven_ingedrukt and self.sprong < self.max_sprong:
                    self.gr = -65 if self.sprong == 0 else -40
                    self.sprong += 1
                self.boven_ingedrukt = True
            else:
                self.boven_ingedrukt = False
 
            if pressed_keys[self.onder]:
                self.rect.y += beneden
        
    
class long_range_att():
    def __init__(self, speler_object, direction):
        self.eigenaar = speler_object
        self.surf = pygame.Surface((20, 20))
        self.surf.fill(blauw)
        self.direction = direction
        if direction == 1:
            self.rect = self.surf.get_rect(midleft=speler_object.rect.midright)
        else:
            self.rect = self.surf.get_rect(midright=speler_object.rect.midleft)
 
    def update(self):
        self.rect.x += (15 * self.direction)
        if self.rect.colliderect(speler_1.rect) and self.eigenaar != speler_1:
            if speler_1.shield.take_hit(10):
                return True 
            speler_1.kb_x = 1 * self.direction * speler_1.schade
            speler_1.kb_y = -0.625 * speler_1.schade
            speler_1.schade *= 20
            speler_1.freeze_timer = 5
            return True
        if self.rect.colliderect(speler_2.rect) and self.eigenaar != speler_2:
            if speler_2.shield.take_hit(10):
                return True
            speler_2.kb_x += 1 * self.direction * speler_2.schade
            speler_2.kb_y -= -0.625 * speler_2.schade
            speler_2.schade *= 20
            speler_2.freeze_timer = 5
            return True
        if self.rect.right >= 1280 or self.rect.left <= 0:
            return True
        return False
 
 
class Punch():
    def __init__(self, speler_object):
        self.eigenaar = speler_object
        self.surf = pygame.Surface((50, 20))
        self.surf.fill(groen)
        self.direction = speler_object.richting
        self.timer = 20
        if self.direction == 1:
            self.rect = self.surf.get_rect(midleft=speler_object.rect.midright)
        else:
            self.rect = self.surf.get_rect(midright=speler_object.rect.midleft)
 
    def update(self):
        self.timer -= 1
        if self.rect.colliderect(speler_1.rect) and self.eigenaar != speler_1:
            speler_1.kb_x += 5 * self.direction * speler_1.schade
            speler_1.kb_y -= -2.5 * speler_1.schade
            speler_1.schade *= 2
            speler_1.freeze_timer = 10
            return True
        if self.rect.colliderect(speler_2.rect) and self.eigenaar != speler_2:
            speler_2.kb_x += 5 * self.direction * speler_2.schade
            speler_2.kb_y -= 2.5 * speler_2.schade
            speler_2.schade *= 2
            speler_2.freeze_timer = 10
            return True
        if self.timer <= 0:
            return True
        return False


class ChargeAttack:
    def __init__(self, speler_object):
        self.eigenaar = speler_object
        self.charging = False
        self.charge_time = 0
        self.max_charge = 2*frame_count

    def start(self):
        if not self.charging:
            self.charging = True
            self.charge_time = 0

    def update(self):
        if self.charging:
            self.charge_time += 1
            self.charge_time = min(self.charge_time, self.max_charge)

    def release(self):
        if self.charging:
            power = self.charge_time / self.max_charge
            self.charging = False
            return ChargedProjectile(self.eigenaar, power)
        return None

class ChargedProjectile:
    def __init__(self, speler, power):
        self.eigenaar = speler
        self.power = power
        self.direction = speler.richting

        size = int(20 + 40 * power)
        self.surf = pygame.Surface((size, size))
        self.surf.fill(rood)

        if self.direction == 1:
            self.rect = self.surf.get_rect(midleft=speler.rect.midright)
        else:
            self.rect = self.surf.get_rect(midright=speler.rect.midleft)

        self.speed = 10 + 10 * power

    def update(self):
        self.rect.x += self.speed * self.direction

        if self.eigenaar != speler_1 :
            target = speler_1
        else:
            target = speler_2

        if self.rect.colliderect(target.rect):
            if target.shield.take_hit(10 * self.power):
                return True 
            knockback = 50 + 200 * self.power
            target.rect.x += knockback * self.direction * target.schade
            target.rect.y -= (10 + 100 * self.power) * target.schade
            target.schade *= (1.5 + self.power)
            target.freeze_timer = int(10 + 20 * self.power)
            return True

        if self.rect.right < 0 or self.rect.left > 1280:
            return True

        return False



