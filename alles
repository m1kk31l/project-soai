class Figuur:
    def __init__(self, kleur):
        self.kleur = kleur
    def teken(self, window):
        pass

class Cirkel(Figuur):
    def __init__(self, kleur, middelpunt, r):
        super().__init__(kleur)
        self.middelpunt = middelpunt
        self.r = r
    def teken(self, window):
        pygame.draw.circle(window, self.kleur, self.middelpunt, self.r)

class Rechthoek(Figuur):
    def __init__(self, kleur, middelpunt, breedte, hoogte):
        super().__init__(kleur)
        self.middelpunt = middelpunt
        self.breedte = breedte
        self.hoogte = hoogte
    def teken(self, window):
        pygame.draw.rect(window, self.kleur, (self.middelpunt[0], self.middelpunt[1], self.breedte, self.hoogte))

